doctype html
html(lang='en')

    head
        - var pageTitle = 'ESW Store – Official Empire State Wrestling Merchandise'
        - var pageDescription = 'Shop official Empire State Wrestling merch. T-shirts and more from Western New York\'s premier indie wrestling promotion.'
        - var canonicalPath = 'store.html'
        include includes/head-seo
        include includes/css

    body

        include includes/header

        include includes/navbar

        // TODO: About page with Calendar, Google Maps, and 
        section.page-section.cta
            .container
                .row
                    .col-xl-9.mx-auto
                        .cta-inner.bg-faded.text-center.rounded
                            h2.section-heading.mb-5
                                span.section-heading-upper Official ESW Merch
                                span.section-heading-lower We're Open
                            ul.list-unstyled.list-hours.mb-5.text-left.mx-auto
                                li.list-unstyled-item.list-hours-item.d-flex
                                    | Sunday
                                    span.ms-auto Closed
                                li.list-unstyled-item.list-hours-item.d-flex
                                    | Monday
                                    span.ms-auto 7:00 AM to 8:00 PM
                                li.list-unstyled-item.list-hours-item.d-flex
                                    | Tuesday
                                    span.ms-auto 7:00 AM to 8:00 PM
                                li.list-unstyled-item.list-hours-item.d-flex
                                    | Wednesday
                                    span.ms-auto 7:00 AM to 8:00 PM
                                li.list-unstyled-item.list-hours-item.d-flex
                                    | Thursday
                                    span.ms-auto 7:00 AM to 8:00 PM
                                li.list-unstyled-item.list-hours-item.d-flex
                                    | Friday
                                    span.ms-auto 7:00 AM to 8:00 PM
                                li.list-unstyled-item.list-hours-item.d-flex
                                    | Saturday
                                    span.ms-auto 9:00 AM to 5:00 PM
                            p.address.mb-5
                                em
                                    strong Shop online at Pro Wrestling Tees
                                    br
                                    | ESW official merchandise
                            p.mb-0
                                small
                                    em
                                        a(href='https://www.prowrestlingtees.com/promotion-tshirts/eswwrestling.html', target='_blank', rel='noopener') prowrestlingtees.com/promotion-tshirts/eswwrestling

        section.page-section.about-heading
            .container
                img.img-fluid.rounded.about-heading-img.mb-3.mb-lg-0(src='assets/img/about.jpg', alt='Empire State Wrestling merchandise')
                .about-heading-content
                    .row
                        .col-xl-9.col-lg-10.mx-auto
                            .bg-faded.rounded.p-5
                                h2.section-heading.mb-4
                                    span.section-heading-upper Rep Your Promotion
                                    span.section-heading-lower About ESW Merchandise
                                p
                                    | Show your support for Empire State Wrestling with official ESW gear. From event tees to classic logos, shop the full lineup at Pro Wrestling Tees and wear Buffalo's premier pro wrestling wherever you go.
                                p.mb-0
                                    | New designs and restocks are added regularly. Follow ESW on social media for drops and event-exclusive merch.

        include includes/footer

        include includes/scripts
