doctype html
html(lang='en')

    head
        - var pageTitle = 'Host ESW – Book Pro Wrestling in WNY | Empire State Wrestling'
        - var pageDescription = 'Host Empire State Wrestling at your venue. Buffalo\'s premier indie wrestling has drawn 1,000+ fans. Book ESW for your event.'
        - var canonicalPath = 'hostesw.html'
        include includes/head-seo
        include includes/css

    body

        include includes/header

        include includes/navbar

        section.page-section.about-heading
            .container
                img.img-fluid.rounded.about-heading-img.mb-3.mb-lg-0(src='assets/img/ub1.jpg', alt='ESW champions Christina Marie, James Sayga, and Vince Valor pose in front of UB')
                .about-heading-content
                    .row
                        .col-xl-9.col-lg-10.mx-auto
                            .bg-faded.rounded.p-5
                                h2.section-heading.mb-4
                                    span.section-heading-upper A Turnkey Featured Attraction for Fairs, Festivals, and Event Centers
                                    span.section-heading-lower Host the Empire State Wrestling Experience
                                p
                                    | Empire State Wrestling (ESW) is Western New York's premier independent professional wrestling promotion. With over 20 years of experience, we specialize in high-energy, family-friendly exhibitions that drive attendance and create a main event atmosphere for your venue.
        section.page-section.cta
            .container
                .row
                    .col-xl-10.mx-auto
                        .cta-inner.bg-faded.rounded.p-5
                            h2.section-heading.mb-4.text-center
                                span.section-heading-upper Proven Drawing Power
                                span.section-heading-lower Why Empire State Wrestling?
                            p.text-center.mb-4
                                | ESW combines a trusted regional brand with marquee talent and a built-in audience across Western New York and beyond.
                            ul.mb-0
                                li.mb-3
                                    strong Established Brand:
                                    |  ESW has produced high-quality live events consistently since 2002.
                                li.mb-3
                                    strong Scalable Attendance:
                                    |  Our shows draw crowds ranging from 400 at local halls to over 1,000 fans at larger venues.
                                li.mb-3
                                    strong Elite Talent:
                                    |  Our ring has featured global stars seen in WWE, including Kevin Owens, Damian Priest, and Johnny Gargano, as well as AEW standouts like MJF, Orange Cassidy, Daniel Garcia, and Ruby Soho.
                                li.mb-3
                                    strong Pro Wrestling Legends:
                                    |  We have hosted industry icons including Kevin Nash, Sgt. Slaughter, Ron Simmons, and Hacksaw Jim Duggan.
                                li
                                    strong Regional Reach:
                                    |  ESW maintains a strong presence across Western New York, the Southern Tier, and the Rochester area, with established fanbases in Pennsylvania and Ontario.
        section.page-section.cta
            .container
                .row
                    .col-xl-10.mx-auto
                        .cta-inner.bg-faded.rounded.p-5
                            h2.section-heading.mb-4.text-center
                                span.section-heading-upper Full-Service Entertainment
                                span.section-heading-lower A Turnkey Production Model
                            ul.mb-0
                                li.mb-3
                                    strong Full Production:
                                    |  ESW supplies a professional wrestling ring, a high-quality sound system, a complete crew, and a roster of world-class athletes.
                                li.mb-3
                                    strong Safety & Standards:
                                    |  We are fully licensed and insured by the New York State Athletic Commission under ESW Productions Inc.
                                li
                                    strong Professional Standards:
                                    |  ESW content is appropriate for all ages, ensuring every show is broadcast-compliant and family friendly.
        section.page-section.cta
            .container
                .row
                    .col-xl-10.mx-auto
                        .cta-inner.bg-faded.rounded.p-5
                            h2.section-heading.mb-4.text-center
                                span.section-heading-upper Flexible Scheduling And Logistics
                                span.section-heading-lower The Venue Experience
                            .row.g-4
                                .col-lg-6
                                    h3.h4.mb-3 Flexible Programming
                                    ul.mb-0
                                        li.mb-3
                                            strong Performance Blocks:
                                            |  Live show segments ranging from 60 minutes to 3 hours.
                                        li
                                            strong Interactive Fan Engagement:
                                            |  Between matches, we provide meet-and-greets, photo opportunities, and merchandise areas to keep fans engaged on-site longer.
                                .col-lg-6
                                    h3.h4.mb-3 Venue Requirements
                                    ul.mb-0
                                        li.mb-3
                                            strong Footprint:
                                            |  A level designated space of approximately 40' x 40'.
                                        li.mb-3
                                            strong Power:
                                            |  Access to a dedicated power source for sound and production equipment.
                                        li
                                            strong Vertical Clearance:
                                            |  High ceilings with a minimum of 13 feet of clearance.
        section.page-section.cta
            .container
                .row.g-4
                    .col-lg-6
                        .cta-inner.bg-faded.rounded.p-5.h-100
                            h2.section-heading.mb-4.text-center
                                span.section-heading-upper Mission-Driven Impact
                                span.section-heading-lower A Dedicated Community Partner
                            ul.mb-0
                                li.mb-3
                                    strong Food Security:
                                    |  We previously hosted non-perishable food drives to benefit FeedMore WNY, Hearts for the Homeless, and Little Free Pantries NT.
                                li
                                    strong Charitable Support:
                                    |  We have a history of fundraising for the P.U.N.T. Pediatric Cancer Collaborative, Ten Lives Club, and local volunteer fire departments.
                    .col-lg-6
                        .cta-inner.bg-faded.rounded.p-5.h-100
                            h2.section-heading.mb-4.text-center
                                span.section-heading-upper Massive Regional Reach
                                span.section-heading-lower Community & Marketing Impact
                            ul.mb-0
                                li.mb-3
                                    strong 29,000+ Followers:
                                    |  Partnering with ESW grants your venue access to our audience across major social media platforms.
                                li.mb-3
                                    strong Media Footprint:
                                    |  Our events have received coverage from WKBW, WIVB, 97 Rock, 103.3 The Edge, and regional newspapers like the Batavia Daily News.
                                li
                                    strong Global Streaming:
                                    |  Our events are featured on IndependentWrestling.TV (IWTV) and YouTube, offering your venue international digital visibility.
        section.page-section.clearfix
            .container
                .carousel.slide#carouselExampleIndicators(data-bs-ride='carousel')
                    .carousel-indicators
                        button(type='button', data-bs-target='#carouselExampleIndicators', data-bs-slide-to='0', class='active', aria-current='true', aria-label='Slide 1')
                        button(type='button', data-bs-target='#carouselExampleIndicators', data-bs-slide-to='1', aria-label='Slide 2')
                        button(type='button', data-bs-target='#carouselExampleIndicators', data-bs-slide-to='2', aria-label='Slide 3')

                    .carousel-inner
                        .carousel-item.active
                            img.d-block.w-100(src='assets/img/bandits1.jpg', alt='Wrestlers Pose for the Buffalo Bandits Wrestling Night')
                        .carousel-item
                            img.d-block.w-100(src='assets/img/ub2.jpg', alt='Mike Skyros vs Cerin Rahne at the University of Buffalo')
                        .carousel-item
                            img.d-block.w-100(src='assets/img/bandits2.jpg', alt='Superbeast driven through a table by the Buffalo Bandits mascot')

                    .carousel-control-prev(href='#carouselExampleIndicators', role='button', data-bs-slide='prev')
                        span.carousel-control-prev-icon(aria-hidden='true')
                        span.visually-hidden Previous
                    .carousel-control-next(href='#carouselExampleIndicators', role='button', data-bs-slide='next')
                        span.carousel-control-next-icon(aria-hidden='true')
                        span.visually-hidden Next
        section.page-section.cta
            .container
                .row
                    .col-xl-10.mx-auto
                        .cta-inner.bg-faded.text-center.rounded.p-5
                            h2.section-heading.mb-4
                                span.section-heading-upper Contact Team
                                span.section-heading-lower Ready to Secure a Date?
                            p.mb-4
                                | Reach out to our management team to begin the collaboration.
                            .row.g-4.text-start
                                .col-md-6
                                    h3.h4 Brett Stymus
                                    p.mb-2 Owner / Operator
                                    p.mb-2
                                        strong Phone:
                                        |  
                                        a(href='tel:7169464814') 716-946-4814
                                    p.mb-0
                                        strong Email:
                                        |  
                                        a(href='mailto:eswoffice@yahoo.com?subject=Interested%20in%20Hosting%20ESW') eswoffice@yahoo.com
                                .col-md-6
                                    h3.h4 David Jarka
                                    p.mb-2 Publicist
                                    p.mb-2
                                        strong Phone:
                                        |  
                                        a(href='tel:7163484598') 716-348-4598
                                    p.mb-0
                                        strong Email:
                                        |  
                                        a(href='mailto:media@eswwrestling.com?subject=Interested%20in%20Hosting%20ESW') media@eswwrestling.com
        include includes/footer

        include includes/scripts
